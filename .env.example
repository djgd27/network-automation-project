# Copy to .env (gitignored) and fill in real values.
#   set -a && source .env && set +a

# NetBox API endpoint and token.
# Token format: nbt_<id>.<secret>  (NetBox 4.x v2 token).
# Generate via the NetBox UI under Admin → Users → API Tokens.
NETBOX_URL=http://127.0.0.1:8000
NETBOX_TOKEN=nbt_CHANGE_ME.CHANGE_ME

# Device login used by Nornir/NAPALM to push configs.
# Lab default for cEOS is admin / admin.
NORNIR_USERNAME=admin
NORNIR_PASSWORD=admin
