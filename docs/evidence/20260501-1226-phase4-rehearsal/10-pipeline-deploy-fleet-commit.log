===== STEP 3c: deploy --commit (full fleet) =====
+vlan 100
+   name TENANT_A_VLAN100
+!
+vrf instance TENANT_A
 !
 interface Ethernet1
+   description p2p to spine1 Eth2
+   no switchport
+   ip address 10.1.1.3/31
 !
 interface Ethernet2
+   description p2p to spine2 Eth2
+   no switchport
+   ip address 10.1.2.3/31
 !
 interface Ethernet3
+   description Access port to server2 (untagged VLAN 100)
+   switchport access vlan 100
+!
+interface Loopback0
+   description Router-ID, BGP source, VTEP source
+   ip address 10.0.0.12/32
+!
+interface Vlan100
+   description Tenant A SVI, anycast gateway 10.100.0.1/24
+   vrf TENANT_A
+   ip address virtual 10.100.0.1/24
+!
+interface Vxlan1
+   description VTEP source, sourced from Loopback0; L2 VNI 10100, L3 VNI 10999
+   vxlan source-interface Loopback0
+   vxlan udp-port 4789
+   vxlan vlan 100 vni 10100
+   vxlan vrf TENANT_A vni 10999
+!
+ip virtual-router mac-address 02:1c:73:00:00:64
 !
-no ip routing
+ip routing
+ip routing vrf TENANT_A
+!
+router bgp 65102
+   router-id 10.0.0.12
+   no bgp default ipv4-unicast
+   neighbor 10.1.1.2 remote-as 65001
+   neighbor 10.1.1.2 description spine1
+   neighbor 10.1.1.2 send-community extended
+   neighbor 10.1.2.2 remote-as 65002
+   neighbor 10.1.2.2 description spine2
+   neighbor 10.1.2.2 send-community extended
+   !
+   vlan 100
+      rd 10.0.0.12:10100
+      route-target both 10100:10100
+      redistribute learned
+   !
+   address-family evpn
+      neighbor 10.1.1.2 activate
+      neighbor 10.1.2.2 activate
+   !
+   address-family ipv4
+      neighbor 10.1.1.2 activate
+      neighbor 10.1.2.2 activate
+      network 10.0.0.12/32
+   !
+   vrf TENANT_A
+      rd 10.0.0.12:10999
+      route-target import evpn 10999:10999
+      route-target export evpn 10999:10999
+      router-id 10.0.0.12
+      redistribute connected

+vlan 101
