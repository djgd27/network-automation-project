+   ip address virtual 10.101.0.1/24
+!
+interface Vxlan1
+   description VTEP source, sourced from Loopback0; L2 VNI 10101, L3 VNI 10999
+   vxlan source-interface Loopback0
+   vxlan udp-port 4789
+   vxlan vlan 101 vni 10101
+   vxlan vrf TENANT_A vni 10999
+!
+ip virtual-router mac-address 02:1c:73:00:00:65
 !
-no ip routing
+ip routing
+ip routing vrf TENANT_A
+!
+router bgp 65103
+   router-id 10.0.0.13
+   no bgp default ipv4-unicast
+   neighbor 10.1.1.4 remote-as 65001
+   neighbor 10.1.1.4 description spine1
+   neighbor 10.1.1.4 send-community extended
+   neighbor 10.1.2.4 remote-as 65002
+   neighbor 10.1.2.4 description spine2
+   neighbor 10.1.2.4 send-community extended
+   !
+   vlan 101
+      rd 10.0.0.13:10101
+      route-target both 10101:10101
