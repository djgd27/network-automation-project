+   !
+   address-family evpn
+      neighbor 10.1.1.4 activate
+      neighbor 10.1.2.4 activate
+   !
+   address-family ipv4
+      neighbor 10.1.1.4 activate
+      neighbor 10.1.2.4 activate
+      network 10.0.0.13/32
+   !
+   vrf TENANT_A
+      rd 10.0.0.13:10999
+      route-target import evpn 10999:10999
+      route-target export evpn 10999:10999
+      router-id 10.0.0.13
+      redistribute connected
